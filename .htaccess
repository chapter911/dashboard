# Disable directory listing

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Keep ACME challenge path reachable for SSL renewals.
    RewriteRule ^\.well-known/ - [L]

    # Skip rewrite if already requesting the public folder directly.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]

</IfModule>
